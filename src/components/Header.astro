---
import Button from '@/components/Button.astro';
import Logo from '@/components/Logo.astro';

const navItems = [
  { label: 'ホーム', href: '/' },
  { label: 'チャンネル', href: '/#channel' },
  { label: '動画プロモーション', href: '/#promotion' },
  { label: 'コラム', href: '/articles/' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  if (href.includes('#')) return false;
  return currentPath.startsWith(href);
};
---

{/* 浮遊するピル型ガラスヘッダー：読み込み時にスッと降りてくる */}
<header class="site-header sticky top-0 z-40 px-3 pt-3 sm:px-4">
  <div
    class="glass mx-auto flex max-w-site flex-wrap items-center justify-between gap-x-6 gap-y-1.5 rounded-[1.75rem] px-5 py-2.5 sm:rounded-full sm:px-7"
  >
    <a href="/" class="inline-block">
      <Logo />
    </a>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-1.5">
      <nav aria-label="メインメニュー">
        <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'nav-link inline-block py-1 transition-colors',
                  isActive(item.href) ? 'font-bold text-ink' : 'text-body hover:text-ink',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <Button href="/contact/" variant="dark" size="sm">お問い合わせ</Button>
    </div>
  </div>
</header>
