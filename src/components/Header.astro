---
import { SITE } from '@/data/site';

const navItems = [
  { label: '記事一覧', href: '/articles/' },
  { label: 'カテゴリー', href: '/category/' },
  { label: '機材・ツール', href: '/equipment/' },
  { label: 'プロフィール', href: '/profile/' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath.startsWith(href);
---

<header class="border-b border-line bg-surface">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="flex flex-wrap items-center justify-between gap-x-6 gap-y-1 py-3 sm:py-4">
      <a href="/" class="group inline-flex items-baseline gap-2">
        <span class="text-lg font-bold text-ink sm:text-xl">{SITE.name}</span>
        <span class="font-mono text-[0.625rem] tracking-widest text-muted uppercase"
          >{SITE.nameEn}</span
        >
      </a>
      <nav aria-label="メインメニュー">
        <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'inline-block border-b-2 py-1 transition-colors',
                  isActive(item.href)
                    ? 'border-accent font-bold text-ink'
                    : 'border-transparent text-body hover:border-line-strong hover:text-ink',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>
