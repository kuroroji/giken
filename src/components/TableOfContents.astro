---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
/** 目次には h2（親階層）だけを番号付きで載せる。h3 以下は載せない（目次が長くなりすぎるため） */
const tocHeadings = headings.filter((h) => h.depth === 2);
---

{
  tocHeadings.length > 0 && (
    <nav
      aria-label="目次"
      class="rounded-card border border-line bg-surface p-5"
    >
      <p class="flex items-center gap-2">
        <span class="font-mono text-[0.625rem] tracking-widest text-muted uppercase">
          Contents
        </span>
        <span class="text-sm font-bold text-ink">目次</span>
      </p>
      <ol class="mt-3 space-y-1.5 text-sm">
        {tocHeadings.map((heading, index) => (
          <li class="flex gap-2">
            <span class="w-4 shrink-0 text-right font-mono text-muted">
              {index + 1}.
            </span>
            <a
              href={`#${heading.slug}`}
              class="text-body underline underline-offset-4 decoration-line-strong hover:text-ink"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
