---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
/** h2 と h3 のみ目次に載せる。番号は h2（親階層）だけに振る */
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
let h2Count = 0;
const items = tocHeadings.map((heading) => ({
  ...heading,
  number: heading.depth === 2 ? ++h2Count : null,
}));
---

{
  items.length > 0 && (
    <nav
      aria-label="目次"
      class="rounded-card border border-line bg-surface p-5"
    >
      <p class="flex items-center gap-2">
        <span class="font-mono text-[0.625rem] tracking-widest text-muted uppercase">
          Contents
        </span>
        <span class="text-sm font-bold text-ink">目次</span>
      </p>
      <ol class="mt-3 space-y-1.5 text-sm">
        {items.map((heading) => (
          <li
            class:list={['flex gap-2', heading.depth === 3 && 'pl-9']}
          >
            {heading.number !== null && (
              <span class="w-4 shrink-0 text-right font-mono text-muted">
                {heading.number}.
              </span>
            )}
            <a
              href={`#${heading.slug}`}
              class="text-body underline underline-offset-4 decoration-line-strong hover:text-ink"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
