---
/**
 * 下層ページ共通の見出しブロック。
 * 英語ラベル（labelEn）は装飾用の小さなモノスペース表記。
 */
interface Props {
  title: string;
  labelEn?: string;
  lede?: string;
}

const { title, labelEn, lede } = Astro.props;
---

<div class="border-b border-line bg-surface">
  <div class="mx-auto max-w-site px-4 py-8 sm:px-6 sm:py-10">
    {
      labelEn && (
        <p class="font-mono text-xs tracking-widest text-accent-strong uppercase">
          {labelEn}
        </p>
      )
    }
    <h1 class="mt-1 text-2xl font-bold text-ink sm:text-3xl">{title}</h1>
    {lede && <p class="mt-3 max-w-2xl text-sm text-muted">{lede}</p>}
  </div>
</div>
