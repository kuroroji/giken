---
import type { Article } from '@/utils/articles';
import ArticleCard from '@/components/ArticleCard.astro';

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
---

<section aria-labelledby="latest-heading">
  <div class="flex items-baseline justify-between gap-4">
    <h2 id="latest-heading" class="text-xl font-bold sm:text-2xl">
      <span class="mr-2 inline-block h-4 w-1 bg-accent" aria-hidden="true"></span>最新記事
    </h2>
    <a
      href="/articles/"
      class="text-sm text-accent-strong underline underline-offset-4 hover:text-ink"
    >
      すべての記事
    </a>
  </div>
  <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {articles.map((article) => <ArticleCard article={article} />)}
  </div>
</section>
