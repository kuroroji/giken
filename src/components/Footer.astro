---
import { SITE, AUTHOR } from '@/data/site';
import { CHANNEL, COLUMN } from '@/data/business';
import Logo from '@/components/Logo.astro';

/** パーティクル装飾の配置（位置・大きさ・速さをばらけさせる） */
const particles = [
  { left: '6%', top: '18%', size: 4, duration: 11, delay: 0 },
  { left: '16%', top: '68%', size: 3, duration: 14, delay: 2 },
  { left: '28%', top: '32%', size: 5, duration: 9, delay: 5 },
  { left: '40%', top: '76%', size: 3, duration: 16, delay: 1 },
  { left: '52%', top: '22%', size: 4, duration: 12, delay: 7 },
  { left: '63%', top: '58%', size: 3, duration: 10, delay: 3 },
  { left: '74%', top: '30%', size: 5, duration: 15, delay: 6 },
  { left: '84%', top: '70%', size: 3, duration: 11, delay: 4 },
  { left: '92%', top: '40%', size: 4, duration: 13, delay: 8 },
  { left: '48%', top: '48%', size: 2, duration: 18, delay: 9 },
];

const year = new Date().getFullYear();
const copyrightYears =
  year > SITE.since ? `${SITE.since}–${year}` : `${SITE.since}`;

const contentLinks = [
  { label: 'くろろじちゃんねる', href: CHANNEL.url, external: true },
  { label: '動画プロモーション', href: '/#promotion', external: false },
  { label: COLUMN.name, href: '/articles/', external: false },
  { label: 'お問い合わせ', href: '/contact/', external: false },
];

const siteLinks = [
  { label: 'プロフィール', href: '/profile/' },
  { label: 'プライバシーポリシー', href: '/privacy-policy/' },
  { label: '広告・アフィリエイトについて', href: '/disclosure/' },
  { label: 'RSS', href: '/rss.xml' },
];

/**
 * SNSリンク領域。src/data/site.ts の AUTHOR.links にURLを設定すると表示される。
 * 追加したい場合はここに1行足すだけでよい。
 */
const snsLinks = [
  { label: 'YouTube', url: AUTHOR.links.youtube },
  { label: 'X（旧Twitter）', url: AUTHOR.links.x },
].filter((link) => link.url !== '');
---

{/* 黒背景の反転フッター：パーティクルがゆっくり漂う */}
<footer class="relative mt-16 overflow-hidden bg-ink text-paper">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    {
      particles.map((p) => (
        <span
          class="particle"
          style={`left:${p.left};top:${p.top};width:${p.size}px;height:${p.size}px;animation-duration:${p.duration}s;animation-delay:${p.delay}s;`}
        />
      ))
    }
  </div>
  <div class="relative mx-auto max-w-site px-4 py-12 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-3">
      <div class="sm:col-span-1">
        <Logo tone="light" />
        <p class="mt-3 text-sm text-line-strong">{SITE.description}</p>
        {
          snsLinks.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-3">
              {snsLinks.map((link) => (
                <li>
                  <a
                    href={link.url}
                    rel="noopener"
                    class="text-sm text-paper underline underline-offset-4 hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
      <nav aria-label="コンテンツ">
        <h2 class="font-mono text-xs tracking-widest text-line-strong uppercase">Contents</h2>
        <ul class="mt-3 space-y-2 text-sm">
          {contentLinks.map((item) => (
            <li>
              <a
                href={item.href}
                rel={item.external ? 'noopener' : undefined}
                target={item.external ? '_blank' : undefined}
                class="text-paper hover:text-white hover:underline"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <nav aria-label="サイト情報">
        <h2 class="font-mono text-xs tracking-widest text-line-strong uppercase">About</h2>
        <ul class="mt-3 space-y-2 text-sm">
          {siteLinks.map((item) => (
            <li>
              <a href={item.href} class="text-paper hover:text-white hover:underline">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
    <p class="mt-10 border-t border-body pt-6 text-center text-xs text-line-strong">
      © {copyrightYears} {SITE.name}
    </p>
  </div>
</footer>
