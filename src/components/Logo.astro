---
/**
 * くろろじ技研のロゴ（テキストロックアップ）。
 * 社名の後ろの小さな四角がアクセント。アイコンは使わない。
 * フッターなど黒背景では tone="light" を指定する。
 */
import { SITE } from '@/data/site';

interface Props {
  tone?: 'dark' | 'light';
}

const { tone = 'dark' } = Astro.props;
---

<span class="inline-flex flex-col leading-tight">
  <span class="inline-flex items-baseline gap-1">
    <span
      class:list={[
        'text-xl font-extrabold tracking-tight sm:text-2xl',
        tone === 'light' ? 'text-white' : 'text-ink',
      ]}>{SITE.name}</span
    >
    <span
      aria-hidden="true"
      class:list={['size-1.5 shrink-0', tone === 'light' ? 'bg-white' : 'bg-ink']}></span>
  </span>
  <span
    class:list={[
      'mt-0.5 font-mono text-[0.5625rem] tracking-[0.32em] uppercase',
      tone === 'light' ? 'text-line-strong' : 'text-muted',
    ]}>{SITE.nameEn}</span
  >
</span>
