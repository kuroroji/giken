---
/**
 * くろろじ技研のロゴ（明朝体のテキスト表記）。
 * フッターなど黒背景では tone="light" を指定する。
 */
import { SITE } from '@/data/site';

interface Props {
  tone?: 'dark' | 'light';
}

const { tone = 'dark' } = Astro.props;
---

<span class="inline-flex items-baseline gap-2">
  <span
    class:list={[
      'font-serif text-lg font-bold tracking-wide sm:text-xl',
      tone === 'light' ? 'text-white' : 'text-ink',
    ]}>{SITE.name}</span
  >
  <span
    class:list={[
      'font-mono text-[0.5625rem] tracking-[0.22em] uppercase',
      tone === 'light' ? 'text-line-strong' : 'text-muted',
    ]}>{SITE.nameEn}</span
  >
</span>
