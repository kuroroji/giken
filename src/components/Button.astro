---
/**
 * サイト共通のボタン（横長のピル型・ガラスデザイン）。
 * href を渡すとリンクに、渡さなければ <button> になる。
 *
 * variant:
 *   dark  … 黒ガラス（最優先のCTA用）
 *   glass … 白ガラス（標準）
 *   light … 白ガラス強め（黒背景セクション内のCTA用）
 */
interface Props {
  href?: string;
  variant?: 'dark' | 'glass' | 'light' | 'youtube' | 'accent';
  size?: 'md' | 'sm';
  external?: boolean;
  type?: 'button' | 'submit';
  /** 幅指定などの追加クラス（例: "w-full sm:w-auto"） */
  class?: string;
}

const {
  href,
  variant = 'glass',
  size = 'md',
  external = false,
  type = 'button',
  class: extraClass = '',
} = Astro.props;

const base =
  'inline-block rounded-full text-center font-bold backdrop-blur-md transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-[0_14px_30px_rgb(17_17_17/0.18)] active:translate-y-0 active:duration-75';
const sizes = {
  md: 'px-6 py-2.5 text-sm',
  sm: 'px-4 py-1.5 text-sm',
};
const variants = {
  dark: 'border border-white/15 bg-ink/85 text-white shadow-[0_8px_30px_rgb(17_17_17/0.18)] hover:bg-ink',
  /** YouTube導線用: 赤の横グラデーション */
  youtube:
    'border border-white/20 bg-gradient-to-r from-[#ff4e45] to-[#b31217] text-white shadow-[0_8px_30px_rgb(179_18_23/0.35)] hover:brightness-110',
  /** お問い合わせ導線用: 藍→紫の横グラデーション */
  accent:
    'border border-white/20 bg-gradient-to-r from-[#3b5bdb] to-[#7048e8] text-white shadow-[0_8px_30px_rgb(59_91_219/0.35)] hover:brightness-110',
  glass:
    'border border-white/70 bg-surface/60 text-ink shadow-[0_8px_30px_rgb(17_17_17/0.05)] hover:border-ink',
  light: 'border border-white/40 bg-white/85 text-ink hover:bg-white',
};
const classes = [base, sizes[size], variants[variant], extraClass];
---

{
  href ? (
    <a
      href={href}
      target={external ? '_blank' : undefined}
      rel={external ? 'noopener' : undefined}
      class:list={classes}
    >
      <slot />
    </a>
  ) : (
    <button type={type} class:list={classes}>
      <slot />
    </button>
  )
}
