---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import EquipmentCard from '@/components/EquipmentCard.astro';
import { EQUIPMENT, type EquipmentGroup } from '@/data/equipment';

const groups: EquipmentGroup[] = ['制作ツール', '機材', 'サービス'];
const groupLabelEn: Record<EquipmentGroup, string> = {
  制作ツール: 'Software',
  機材: 'Hardware',
  サービス: 'Services',
};
---

<BaseLayout
  title="使用機材・利用サービス"
  description="くろろじ技研で実際に使用している制作ツール・機材・サービスの一覧です。稼働中のものと検証中のものを分けて掲載しています。"
>
  <PageHeader
    title="使用機材・利用サービス"
    labelEn="Equipment & Tools"
    lede="実際に使っているものだけを掲載しています。「稼働中」は現在の制作フローで使用中、「検証中」は導入を試している段階のものです。"
  />
  <div class="mx-auto max-w-site px-4 py-8 sm:px-6">
    <Breadcrumbs items={[{ label: '使用機材・利用サービス' }]} />

    <div class="mt-6 space-y-10">
      {
        groups.map((group) => {
          const items = EQUIPMENT.filter((e) => e.group === group);
          return (
            items.length > 0 && (
              <section aria-label={group}>
                <h2 class="flex items-baseline gap-3 text-lg font-bold">
                  <span
                    class="inline-block h-4 w-1 bg-accent"
                    aria-hidden="true"
                  />
                  {group}
                  <span class="font-mono text-xs font-normal tracking-widest text-muted uppercase">
                    {groupLabelEn[group]}
                  </span>
                </h2>
                <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                  {items.map((item) => (
                    <EquipmentCard item={item} />
                  ))}
                </div>
              </section>
            )
          );
        })
      }
    </div>

    <p class="mt-10 rounded-card border border-line bg-accent-faint px-4 py-3 text-xs text-body">
      掲載している機材・サービスの詳しい使用感は、順次記事としてレポートしていきます。記事内にアフィリエイトリンクを含む場合は、各記事に表記があります。
    </p>
  </div>
</BaseLayout>
