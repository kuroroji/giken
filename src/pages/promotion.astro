---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import { AUTHOR, CONTACT } from '@/data/site';
import { PROMOTION, CONSULTATION, CONTACT_TOPICS } from '@/data/business';

/** 見本として掲載するプロモーション動画 */
const sampleVideos = [
  { id: 'hu1G8PE8UiQ', title: 'プロモーション動画の事例 1' },
  { id: 'yo9ZtW9L1Ow', title: 'プロモーション動画の事例 2' },
];

const description =
  'ゲーム会社・パブリッシャー様向けの動画プロモーションのご案内。おすすめのゲームを、くろろじ自身が楽しみながら紹介して届けます。';
---

<BaseLayout title="動画プロモーション" description={description}>
  {/* ファーストビュー(黒): トップとの反転でLPだと分かる導入 */}
  <section class="relative overflow-hidden border-b border-line bg-ink-navy">
    <div class="relative mx-auto max-w-site px-4 py-10 sm:px-6 sm:py-16">
      <div class="grid items-end gap-8 lg:grid-cols-[1fr_20rem]">
        <div class="relative z-10">
          {/* メインコピー+丸型アバターの2カラム（lg未満）。文字サイズはアバター分を引いた幅にvw連動 */}
          <div class="mt-4 flex items-center justify-between gap-3">
            <h1 class="font-serif text-[min(5.9vw,3rem)] leading-snug font-bold text-white">
              あなたのゲームを、<br />楽しみながら広めます。
            </h1>
            <img
              src={AUTHOR.avatar}
              alt="くろろじのアイコン"
              width="80"
              height="80"
              class="size-20 shrink-0 rounded-full border-2 border-white/40 object-cover object-top drop-shadow-[0_8px_20px_rgb(0_0_0/0.4)] lg:hidden"
            />
          </div>
          <p class="mt-5 max-w-2xl text-sm leading-relaxed text-white/80 sm:text-base">
            ゲーム序盤を実際に遊んで紹介する「序盤実況」。おすすめのゲームとして、楽しみながら紹介させていただきます。
          </p>
          <div class="mt-7 flex max-w-md flex-col gap-3 sm:max-w-none sm:flex-row sm:items-center">
            <Button href="#contact-form" variant="light" class="w-full sm:w-auto"
              >動画案件を相談する</Button
            >
            <Button href={PROMOTION.playlistUrl} variant="glass" external class="w-full sm:w-auto"
              >過去のプロモーション動画を見る</Button
            >
          </div>
          <ul class="mt-6 flex flex-wrap gap-2 text-xs">
            <li class="rounded-full border border-white/25 px-3 py-1 text-white/85">チャンネル登録者 約3万人</li>
            <li class="rounded-full border border-white/25 px-3 py-1 text-white/85">実績:{PROMOTION.clients.slice(0, 2).join('、')} ほか</li>
            <li class="rounded-full border border-white/25 px-3 py-1 text-white/85">納品 最短翌日〜1週間</li>
          </ul>
        </div>
        {/* 立ち絵：lg以上のみセクション下端に接地させ大きめに表示。lg未満は丸型アバター（実績バッジの横）で代替 */}
        <div class="hidden self-end lg:-mb-16 lg:block">
          <img
            src={AUTHOR.standingImage}
            alt="くろろじのイラスト"
            width="720"
            height="931"
            class="w-full drop-shadow-[0_16px_40px_rgb(0_0_0/0.45)]"
          />
        </div>
      </div>
    </div>
  </section>

  {/* 届く仕組み+実績(白) */}
  <section class="border-b border-line">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-ink sm:text-3xl">
        「刺さる人」に届く仕組み
      </h2>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-body">
        くろろじちゃんねるの視聴者は、ハクスラ・ローグライク・インディーゲームを能動的に探しているゲーマーです。実際に遊びながら「誰に刺さるか」を言語化して届けるので、ダウンロードや購入につながりやすいのが特徴です。
      </p>
      {/* モバイルは縦型の図解 */}
      <svg viewBox="0 0 360 310" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="ゲームをくろろじが遊び、誰に刺さるかを言語化して、約3万人の視聴者へ届ける流れ" class="mx-auto mt-8 w-full max-w-xs sm:hidden">
        <defs>
          <marker id="pm" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 1 L 9 5 L 0 9" fill="none" stroke="#111" stroke-width="1.5" stroke-linecap="round"/>
          </marker>
        </defs>
        <g font-family="sans-serif">
          <rect x="20" y="12" width="320" height="60" rx="12" fill="#fff" stroke="#111" stroke-width="1.5"/>
          <text x="180" y="38" text-anchor="middle" font-size="15" font-weight="600" fill="#111">貴社のゲーム</text>
          <text x="180" y="58" text-anchor="middle" font-size="11" fill="#555">新作・インディー・埋もれた良作</text>
          <line x1="180" y1="72" x2="180" y2="98" stroke="#111" stroke-width="1.5" marker-end="url(#pm)"/>
          <rect x="20" y="104" width="320" height="66" rx="12" fill="#111"/>
          <text x="180" y="132" text-anchor="middle" font-size="15" font-weight="600" fill="#fff">くろろじが遊ぶ</text>
          <text x="180" y="152" text-anchor="middle" font-size="11" fill="#ccc">「誰に刺さるか」を言語化</text>
          <line x1="180" y1="170" x2="180" y2="196" stroke="#111" stroke-width="1.5" marker-end="url(#pm)"/>
          <rect x="20" y="202" width="320" height="60" rx="12" fill="#fff" stroke="#111" stroke-width="1.5"/>
          <text x="180" y="228" text-anchor="middle" font-size="15" font-weight="600" fill="#111">約3万人にリーチ</text>
          <text x="180" y="248" text-anchor="middle" font-size="11" fill="#555">ゲームを探しているゲーマー</text>
          <text x="180" y="294" text-anchor="middle" font-size="11" fill="#555">「面白そう」で終わらせず「自分に合いそう」まで伝える</text>
        </g>
      </svg>
      <svg viewBox="0 0 720 180" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="ゲームをくろろじが遊び、誰に刺さるかを言語化して、ゲームを探している視聴者へ届ける流れ" class="mx-auto mt-8 hidden w-full max-w-2xl sm:block">
        <defs>
          <marker id="pa" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 1 L 9 5 L 0 9" fill="none" stroke="#111" stroke-width="1.5" stroke-linecap="round"/>
          </marker>
        </defs>
        <g font-family="sans-serif">
          <rect x="16" y="60" width="170" height="60" rx="12" fill="#fff" stroke="#111" stroke-width="1.5"/>
          <text x="101" y="86" text-anchor="middle" font-size="15" font-weight="600" fill="#111">貴社のゲーム</text>
          <text x="101" y="106" text-anchor="middle" font-size="11" fill="#555">新作・インディー・埋もれた良作</text>
          <line x1="186" y1="90" x2="264" y2="90" stroke="#111" stroke-width="1.5" marker-end="url(#pa)"/>
          <rect x="270" y="45" width="180" height="90" rx="12" fill="#111"/>
          <text x="360" y="80" text-anchor="middle" font-size="15" font-weight="600" fill="#fff">くろろじが遊ぶ</text>
          <text x="360" y="102" text-anchor="middle" font-size="11" fill="#ccc">「誰に刺さるか」を言語化</text>
          <line x1="450" y1="90" x2="528" y2="90" stroke="#111" stroke-width="1.5" marker-end="url(#pa)"/>
          <rect x="534" y="60" width="170" height="60" rx="12" fill="#fff" stroke="#111" stroke-width="1.5"/>
          <text x="619" y="86" text-anchor="middle" font-size="15" font-weight="600" fill="#111">約3万人にリーチ</text>
          <text x="619" y="106" text-anchor="middle" font-size="11" fill="#555">ゲームを探しているゲーマー</text>
          <text x="360" y="168" text-anchor="middle" font-size="12" fill="#555">「面白そう」で終わらせず、「自分に合いそう」まで伝える</text>
        </g>
      </svg>
      <p class="mx-auto mt-4 max-w-2xl text-xs leading-relaxed text-muted">
        ※再生数は、ゲームの魅力やキービジュアルの「見栄え」によって変動します。見栄えがどれほど大切かは、僕自身がサムネイル制作で痛感してきたことでもあり、<a
          href="https://note.com/kuroroji/n/n74c4d461a335"
          target="_blank"
          rel="noopener"
          class="underline underline-offset-2 hover:text-ink">noteの記事</a
        >で詳しく解説しています。
      </p>

      <h3 class="mt-12 font-serif text-xl font-bold text-ink">これまでの実績</h3>
      <ul class="mt-5 grid gap-2 text-sm text-body sm:grid-cols-2">
        {PROMOTION.clients.map((client) => (
          <li class="flex gap-2">
            <span aria-hidden="true" class="mt-2.5 block h-px w-3 shrink-0 bg-ink" />
            {client}
          </li>
        ))}
      </ul>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <figure class="glass rounded-card p-6">
          <p class="font-serif text-3xl leading-none text-ink/20" aria-hidden="true">“</p>
          <blockquote class="mt-1 leading-relaxed text-ink">動画をご依頼したところ、売上が増えました。</blockquote>
          <figcaption class="mt-3 text-xs text-muted">ご依頼いただいたゲーム会社様より</figcaption>
        </figure>
        <figure class="glass rounded-card p-6">
          <p class="font-serif text-3xl leading-none text-ink/20" aria-hidden="true">“</p>
          <blockquote class="mt-1 leading-relaxed text-ink">楽しんでいる様子を動画にしていただき、感謝しています。</blockquote>
          <figcaption class="mt-3 text-xs text-muted">ご依頼いただいたゲーム会社様より</figcaption>
        </figure>
      </div>
      <p class="mt-3 text-xs text-muted">※効果はタイトルや施策内容によって異なります。</p>
      <div class="mt-6">
        <Button href={PROMOTION.playlistUrl} variant="dark" external
          >実績動画を再生リストで見る</Button
        >
      </div>
    </div>
  </section>

  {/* 見本動画(黒) */}
  <section class="relative overflow-hidden border-b border-line bg-ink-navy">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-white sm:text-3xl">動画の見本</h2>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/80">
        実際に公開しているプロモーション動画です。<span class="font-bold text-white">楽しみながら紹介するのが特徴です。</span>広告であっても、視聴者にとって「面白いゲームに出会える動画」であることを大切にしています。
      </p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {sampleVideos.map((video) => (
          <div class="aspect-video w-full overflow-hidden rounded-card border border-white/20">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="h-full w-full"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 対応できること+進め方(白) */}
  <section class="border-b border-line">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-ink sm:text-3xl">対応できること</h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {PROMOTION.services.map((service) => (
          <div class="glass rounded-card p-5">
            <h3 class="font-bold text-ink">{service.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-body">{service.body}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-xs text-muted">{PROMOTION.disclosureNote}</p>

      <h3 class="mt-12 font-serif text-xl font-bold text-ink">ご相談から公開までの流れ</h3>
      {/* モバイルは縦型の流れ図 */}
      <svg viewBox="0 0 360 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="ご相談、プレイと制作、公開の3ステップ" class="mx-auto mt-6 w-full max-w-xs sm:hidden">
        <g font-family="sans-serif">
          <rect x="20" y="12" width="320" height="52" rx="10" fill="#fff" stroke="#111" stroke-width="1.5"/>
          <text x="180" y="43" text-anchor="middle" font-size="14" font-weight="600" fill="#111">ご相談</text>
          <line x1="180" y1="64" x2="180" y2="88" stroke="#111" stroke-width="1.5" marker-end="url(#pm)"/>
          <rect x="20" y="94" width="320" height="52" rx="10" fill="#fff" stroke="#111" stroke-width="1.5"/>
          <text x="180" y="125" text-anchor="middle" font-size="14" font-weight="600" fill="#111">プレイ・制作</text>
          <line x1="180" y1="146" x2="180" y2="170" stroke="#111" stroke-width="1.5" marker-end="url(#pm)"/>
          <rect x="20" y="176" width="320" height="52" rx="10" fill="#111"/>
          <text x="180" y="207" text-anchor="middle" font-size="14" font-weight="600" fill="#fff">公開</text>
          <text x="180" y="258" text-anchor="middle" font-size="11" fill="#555">納期は最短で翌日、通常でも1週間後には納品可能です</text>
          <text x="180" y="276" text-anchor="middle" font-size="11" fill="#555">公開後の振り返りも、必要に応じて対応します</text>
        </g>
      </svg>
      <svg viewBox="0 0 720 150" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="ご相談、プレイと制作、公開の3ステップ" class="mx-auto mt-6 hidden w-full max-w-2xl sm:block">
        <defs>
          <marker id="pb" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M 0 1 L 9 5 L 0 9" fill="none" stroke="#111" stroke-width="1.5" stroke-linecap="round"/>
          </marker>
        </defs>
        <g font-family="sans-serif">
          {['ご相談', 'プレイ・制作', '公開'].map((label, i) => (
            <>
              <rect x={70 + i * 220} y="40" width="160" height="56" rx="10" fill={i === 2 ? '#111' : '#fff'} stroke="#111" stroke-width="1.5"/>
              <text x={150 + i * 220} y="73" text-anchor="middle" font-size="14" font-weight="600" fill={i === 2 ? '#fff' : '#111'}>{label}</text>
              {i < 2 && (
                <line x1={230 + i * 220} y1="68" x2={262 + i * 220} y2="68" stroke="#111" stroke-width="1.5" marker-end="url(#pb)"/>
              )}
            </>
          ))}
          <text x="360" y="126" text-anchor="middle" font-size="12" fill="#555">納期は最短で翌日、通常でも1週間後には納品可能です</text>
          <text x="360" y="144" text-anchor="middle" font-size="12" fill="#555">公開後の振り返りも、必要に応じて対応します</text>
        </g>
      </svg>
    </div>
  </section>

  {/* ゲームに関する相談(白・ガラス) */}
  <section class="border-b border-line bg-surface">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-ink sm:text-3xl">
        ゲームに関するご相談も受け付けています
      </h2>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-body">
        動画プロモーション以外にも、「ゲームの届け方」に関するお手伝いができます。実況者として、そして数多くのゲームを遊んで紹介してきた立場から、率直なフィードバックをお返しします。
      </p>
      <div class="mt-7 grid gap-5 sm:grid-cols-3">
        <div class="glass rounded-card p-5">
          <p class="flex items-baseline gap-2">
            <span class="font-mono text-[0.625rem] tracking-widest text-muted uppercase">Point</span>
            <span class="font-serif text-4xl leading-none font-bold text-ink">01</span>
          </p>
          <h3 class="mt-3 font-bold text-ink">チュートリアルの分かりやすさ</h3>
          <p class="mt-2 text-sm leading-relaxed text-body">
            序盤で魅力が伝わるか、初見プレイヤーがつまずくポイントはどこかを、実際に遊んで共有します。
          </p>
        </div>
        <div class="glass rounded-card p-5">
          <p class="flex items-baseline gap-2">
            <span class="font-mono text-[0.625rem] tracking-widest text-muted uppercase">Point</span>
            <span class="font-serif text-4xl leading-none font-bold text-ink">02</span>
          </p>
          <h3 class="mt-3 font-bold text-ink">YouTubeでウケる傾向</h3>
          <p class="mt-2 text-sm leading-relaxed text-body">
            実況・配信で紹介されやすいゲームの傾向や、動画映えする要素についてお伝えします。
          </p>
        </div>
        <div class="glass rounded-card p-5">
          <p class="flex items-baseline gap-2">
            <span class="font-mono text-[0.625rem] tracking-widest text-muted uppercase">Point</span>
            <span class="font-serif text-4xl leading-none font-bold text-ink">03</span>
          </p>
          <h3 class="mt-3 font-bold text-ink">ゲームへのフィードバック</h3>
          <p class="mt-2 text-sm leading-relaxed text-body">
            ゲーム序盤を数多く遊んできた経験から、序盤のゲームプレイ改善につながる率直なフィードバックをお返しします。「誰に刺さりそうか」の視点も添えて。
          </p>
        </div>
      </div>
      <p class="mt-5 text-xs text-muted">{CONSULTATION.note}</p>
    </div>
  </section>

  {/* お問い合わせフォーム(黒で締め) */}
  <section id="contact-form" class="relative overflow-hidden bg-ink-navy">
    <div class="mx-auto max-w-article px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-white sm:text-3xl">お問い合わせ</h2>
      <p class="mt-3 text-sm leading-relaxed text-white/80">
        ゲームタイトルと想定内容をお聞かせください。内容を確認のうえ、ご返信いたします。
      </p>
      <form class="mt-8 space-y-5" method="post" action="#contact-form">
        <div>
          <label for="pf-company" class="block text-sm font-bold text-white">会社名</label>
          <input id="pf-company" name="company" type="text" placeholder="株式会社◯◯"
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40" />
        </div>
        <div>
          <label for="pf-name" class="block text-sm font-bold text-white">お名前 *</label>
          <input id="pf-name" name="name" type="text" required placeholder="山田 太郎"
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40" />
        </div>
        <div>
          <label for="pf-email" class="block text-sm font-bold text-white">メールアドレス *</label>
          <input id="pf-email" name="email" type="email" required placeholder="you@example.com"
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40" />
        </div>
        <div>
          <label for="pf-topic" class="block text-sm font-bold text-white">ご用件 *</label>
          <select id="pf-topic" name="topic" required
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white">
            {CONTACT_TOPICS.map((topic) => (
              <option value={topic} class="text-ink">{topic}</option>
            ))}
            <option value="その他" class="text-ink">その他</option>
          </select>
        </div>
        <div>
          <label for="pf-message" class="block text-sm font-bold text-white">ご相談内容 *</label>
          <textarea id="pf-message" name="message" rows="5" required
            placeholder="ゲームタイトル、希望される施策、時期などをご記入ください"
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40"></textarea>
        </div>
        <Button type="submit" variant="light" class="w-full sm:w-auto">送信する</Button>
      </form>
    </div>
  </section>
</BaseLayout>
