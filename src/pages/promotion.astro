---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import { SITE, CONTACT } from '@/data/site';
import { CHANNEL, PROMOTION, CONSULTATION, CONTACT_TOPICS } from '@/data/business';

/** 見本として掲載するプロモーション動画 */
const sampleVideos = [
  { id: 'hu1G8PE8UiQ', title: 'プロモーション動画の事例 1' },
  { id: 'yo9ZtW9L1Ow', title: 'プロモーション動画の事例 2' },
];

const description =
  'ゲーム会社・パブリッシャー様向けの動画プロモーションのご案内。実際のプレイを通して「どんなゲームで、誰におすすめか」が伝わる紹介動画を制作します。';
---

<BaseLayout title="動画プロモーション" description={description}>
  {/* ファーストビュー: CTAをここに置く */}
  <section class="hero-bg relative overflow-hidden border-b border-line">
    <div class="relative mx-auto max-w-site px-4 py-14 sm:px-6 sm:py-20">
      <p class="font-mono text-xs tracking-widest text-muted uppercase">
        Video Promotion
      </p>
      <h1 class="mt-4 text-3xl leading-snug font-bold text-ink sm:text-5xl">
        あなたのゲームを、<br />必要としているプレイヤーへ。
      </h1>
      <p class="mt-5 max-w-2xl text-sm leading-relaxed text-body sm:text-base">
        新作ゲームの実況・紹介動画・まとめ企画など、タイトルの特徴に合わせたプロモーションをご提案します。「どんなゲームで、誰におすすめか」が伝わる紹介を大切にしています。
      </p>
      <div class="mt-7 flex max-w-md flex-col gap-3 sm:max-w-none sm:flex-row sm:items-center">
        <Button href="#contact-form" variant="dark" class="w-full sm:w-auto"
          >動画プロモーションを相談する</Button
        >
        <Button href={PROMOTION.playlistUrl} variant="glass" external class="w-full sm:w-auto"
          >過去のプロモーション動画を見る</Button
        >
      </div>
      <p class="mt-4 text-xs text-muted">
        実績：{PROMOTION.clients.slice(0, 2).join('、')} ほか
      </p>
    </div>
  </section>

  {/* 実績とお客様の声 */}
  <section class="border-b border-line bg-ink">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-white sm:text-3xl">実績</h2>
      <ul class="mt-6 grid gap-2 text-sm text-white/85 sm:grid-cols-2">
        {PROMOTION.clients.map((client) => (
          <li class="flex gap-2">
            <span aria-hidden="true" class="mt-2.5 block h-px w-3 shrink-0 bg-white/60" />
            {client}
          </li>
        ))}
      </ul>
      <div class="glass-dark mt-8 rounded-card p-6">
        <p class="font-mono text-xs tracking-widest text-white/60 uppercase">Voice</p>
        <p class="mt-2 leading-relaxed text-white">
          動画公開後に「売上が増えた」というお声を、これまでに<span class="font-bold">2件</span>の事例として伺っています。
        </p>
        <p class="mt-2 text-xs text-white/60">
          ※効果はタイトルや施策内容によって異なります。
        </p>
      </div>
    </div>
  </section>

  {/* 見本動画 */}
  <section class="border-b border-line bg-surface">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-ink sm:text-3xl">動画の見本</h2>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-body">
        実際に公開しているプロモーション動画です。ゲームの手触りと「誰に刺さるか」が伝わる構成を心がけています。
      </p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {sampleVideos.map((video) => (
          <div class="aspect-video w-full overflow-hidden rounded-card border border-line">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="h-full w-full"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 対応できること */}
  <section class="border-b border-line">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-ink sm:text-3xl">対応できること</h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {PROMOTION.services.map((service) => (
          <div class="glass rounded-card p-5">
            <h3 class="font-bold text-ink">{service.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-body">{service.body}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-xs text-muted">{PROMOTION.disclosureNote}</p>
    </div>
  </section>

  {/* ゲームに関する相談 */}
  <section class="border-b border-line bg-surface">
    <div class="mx-auto max-w-site px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-ink sm:text-3xl">
        ゲームに関するご相談も受け付けています
      </h2>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-body">
        {CONSULTATION.description}
      </p>
      <ul class="mt-5 flex flex-wrap gap-2 text-xs">
        {CONSULTATION.themes.map((theme) => (
          <li class="rounded-full border border-line px-3 py-1 text-body">{theme}</li>
        ))}
      </ul>
      <p class="mt-4 text-xs text-muted">{CONSULTATION.note}</p>
    </div>
  </section>

  {/* お問い合わせフォーム */}
  <section id="contact-form" class="bg-ink">
    <div class="mx-auto max-w-article px-4 py-12 sm:px-6 sm:py-16">
      <h2 class="font-serif text-2xl font-bold text-white sm:text-3xl">お問い合わせ</h2>
      <p class="mt-3 text-sm leading-relaxed text-white/80">
        ゲームタイトルと想定内容をお聞かせください。内容を確認のうえ、ご提案いたします。
      </p>
      <form class="mt-8 space-y-5" method="post" action="#contact-form">
        <div>
          <label for="pf-company" class="block text-sm font-bold text-white">会社名</label>
          <input
            id="pf-company"
            name="company"
            type="text"
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40"
            placeholder="株式会社◯◯"
          />
        </div>
        <div>
          <label for="pf-name" class="block text-sm font-bold text-white">お名前 *</label>
          <input
            id="pf-name"
            name="name"
            type="text"
            required
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40"
            placeholder="山田 太郎"
          />
        </div>
        <div>
          <label for="pf-email" class="block text-sm font-bold text-white">メールアドレス *</label>
          <input
            id="pf-email"
            name="email"
            type="email"
            required
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="pf-topic" class="block text-sm font-bold text-white">ご用件 *</label>
          <select
            id="pf-topic"
            name="topic"
            required
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white"
          >
            {CONTACT_TOPICS.map((topic) => (
              <option value={topic} class="text-ink">{topic}</option>
            ))}
            <option value="その他" class="text-ink">その他</option>
          </select>
        </div>
        <div>
          <label for="pf-message" class="block text-sm font-bold text-white">ご相談内容 *</label>
          <textarea
            id="pf-message"
            name="message"
            rows="5"
            required
            class="mt-1.5 w-full rounded-card border border-white/25 bg-white/10 px-4 py-2.5 text-sm text-white placeholder-white/40"
            placeholder="ゲームタイトル、希望される施策、時期などをご記入ください"></textarea>
        </div>
        <Button type="submit" variant="light" class="w-full sm:w-auto">送信する</Button>
        <p class="text-xs leading-relaxed text-white/60">{CONTACT.note}</p>
      </form>
    </div>
  </section>
</BaseLayout>
