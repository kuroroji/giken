---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { SITE, AUTHOR } from '@/data/site';

const socialLinks = [
  { label: 'YouTube', url: AUTHOR.links.youtube },
  { label: 'X（旧Twitter）', url: AUTHOR.links.x },
].filter((link) => link.url !== '');

/** 運営者の構造化データ（Person + WebSite運営情報） */
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    mainEntity: {
      '@type': 'Person',
      name: AUTHOR.name,
      description: AUTHOR.bio,
      jobTitle: AUTHOR.role,
      url: new URL('/profile/', Astro.site).toString(),
      ...(socialLinks.length > 0
        ? { sameAs: socialLinks.map((link) => link.url) }
        : {}),
    },
  },
];
---

<BaseLayout
  title="プロフィール"
  description={`${SITE.name}の運営者プロフィールです。${AUTHOR.bio}`}
  jsonLd={jsonLd}
>
  <PageHeader title="プロフィール" labelEn="Profile" />
  <div class="mx-auto max-w-article px-4 py-8 sm:px-6">
    <Breadcrumbs items={[{ label: 'プロフィール' }]} />

    <div class="mt-6 flex items-center gap-5">
      <img
        src={AUTHOR.avatar}
        alt="くろろじのプロフィールイラスト"
        width="720"
        height="720"
        class="size-20 shrink-0 rounded-full border border-line object-cover object-top"
      />
      <div>
        <p class="text-xl font-bold text-ink">{AUTHOR.name}</p>
        <p class="mt-1 text-sm text-muted">{AUTHOR.role}</p>
      </div>
    </div>

    <div class="article-body mt-8">
      <p>{AUTHOR.bio}</p>

      <h2>このサイトについて</h2>
      <p>
        「{SITE.name}」は、{AUTHOR.name}の活動拠点となる公式サイトです。
        {SITE.description}
      </p>
      <p>
        視聴者の方にはYouTube動画と記事を、ゲーム会社・パブリッシャーの方には動画プロモーションのご相談窓口を、これからゲームを届けたい開発者の方には無料相談の入口を用意しています。
      </p>

      <h2>主な活動</h2>
      <ul>
        <li>YouTubeチャンネル「くろろじちゃんねる」の運営（ゲーム発掘・序盤実況・おすすめまとめ）</li>
        <li>ゲーム会社・パブリッシャー向けの動画プロモーション</li>
        <li>ゲーム・YouTube運営に関する記事メディアの執筆</li>
        <li>ゲームの届け方に関する相談対応</li>
      </ul>

      {
        socialLinks.length > 0 && (
          <>
            <h2>リンク</h2>
            <ul>
              {socialLinks.map((link) => (
                <li>
                  <a href={link.url} rel="noopener">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }

      <h2>お問い合わせ</h2>
      <p>
        サイトへのご意見・ご依頼は<a href="/contact/">お問い合わせ案内</a
        >をご覧ください。
      </p>
    </div>
  </div>
</BaseLayout>
