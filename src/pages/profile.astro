---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { SITE, AUTHOR } from '@/data/site';
import { PROMOTION } from '@/data/business';

/** noteの自己紹介記事（詳しい経歴はこちらに誘導する） */
const NOTE_PROFILE_URL = 'https://note.com/kuroroji/n/n9af50794245b';

const socialLinks = [
  { label: 'YouTube', url: AUTHOR.links.youtube },
  { label: 'X（旧Twitter）', url: AUTHOR.links.x },
].filter((link) => link.url !== '');

/** 運営者の構造化データ（Person + WebSite運営情報） */
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    mainEntity: {
      '@type': 'Person',
      name: AUTHOR.name,
      description: AUTHOR.bio,
      jobTitle: AUTHOR.role,
      url: new URL('/profile/', Astro.site).toString(),
      ...(socialLinks.length > 0
        ? { sameAs: socialLinks.map((link) => link.url) }
        : {}),
    },
  },
];
---

<BaseLayout
  title="プロフィール"
  description={`${SITE.name}の運営者プロフィールです。${AUTHOR.bio}`}
  jsonLd={jsonLd}
>
  <PageHeader title="プロフィール" labelEn="Profile" />
  <div class="mx-auto max-w-article px-4 py-8 sm:px-6">
    <Breadcrumbs items={[{ label: 'プロフィール' }]} />

    <div class="mt-6 flex items-center gap-5">
      <img
        src={AUTHOR.avatar}
        alt="くろろじのプロフィールイラスト"
        width="720"
        height="720"
        class="size-20 shrink-0 rounded-full border border-line object-cover object-top"
      />
      <div>
        <p class="text-xl font-bold text-ink">{AUTHOR.name}</p>
        <p class="mt-1 text-sm text-muted">{AUTHOR.role}</p>
      </div>
    </div>

    <div class="article-body mt-8">
      <p>{AUTHOR.bio}</p>

      <h2>基本情報</h2>
      <ul>
        <li><strong>名前</strong>:くろろじ</li>
        <li><strong>性別</strong>:男性</li>
        <li><strong>生年月日</strong>:1988年10月3日</li>
        <li><strong>基本性能</strong>:究極的なライトゲーマー。やり込みは苦手ですが、ゲームを探して人におすすめすることが好きです。</li>
      </ul>

      <h2>このサイトについて</h2>
      <p>
        「{SITE.name}」は、{AUTHOR.name}の公式サイトです。
        {SITE.description}
      </p>
      <p>
        視聴者の方にはYouTube動画と記事を、ゲーム会社・パブリッシャーの方には動画プロモーションのご相談窓口を、これからゲームを届けたい開発者の方には無料相談の入口を用意しています。
      </p>

      <h2>主な活動</h2>
      <ul>
        <li>YouTubeチャンネル「くろろじちゃんねる」の運営（ゲーム発掘・序盤実況・おすすめまとめ）</li>
        <li>ゲーム会社・パブリッシャー向けの動画プロモーション</li>
        <li>ゲーム・YouTube運営に関する記事メディアの執筆</li>
        <li>ゲームの届け方に関する相談対応</li>
      </ul>

      <h2>経歴</h2>
      <p>
        22歳からWEB業界でキャリアを重ね、WEBデザイン、広告バナー制作、Spineアニメーション（ソーシャルゲームのキャラクター制作）、WEBコーディング、WEBメディアサイトの運用、SEOなど、制作から運用まで幅広い実務を約12年経験しました。
      </p>
      <p>
        YouTubeへの動画投稿は29歳のときに趣味として開始。その後フリーランスとしてWEB制作の仕事を続けながら、36歳からYouTube活動を本格化し、毎日投稿を開始しました。2025年にゲームの発掘・紹介スタイルへ転換し、現在の「くろろじちゃんねる」の形になっています。
      </p>
      <p>
        これまでの経緯をもっと詳しく知りたい方は、<a
          href={NOTE_PROFILE_URL}
          target="_blank"
          rel="noopener">noteの自己紹介記事</a
        >をご覧ください。
      </p>

      <h2>動画プロモーション実績</h2>
      <ul>
        {PROMOTION.clients.map((client) => <li>{client}</li>)}
      </ul>
      <p>
        ゲーム会社・パブリッシャー様向けの動画プロモーションについては、<a
          href="/contact/">お問い合わせ</a
        >からご相談いただけます。
      </p>

      {
        socialLinks.length > 0 && (
          <>
            <h2>リンク</h2>
            <ul>
              {socialLinks.map((link) => (
                <li>
                  <a href={link.url} rel="noopener">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )
      }

      <h2>お問い合わせ</h2>
      <p>
        サイトへのご意見・ご依頼は<a href="/contact/">お問い合わせ案内</a
        >をご覧ください。
      </p>
    </div>
  </div>
</BaseLayout>
