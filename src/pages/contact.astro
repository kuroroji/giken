---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { CONTACT } from '@/data/site';
import { CONSULTATION, CONTACT_TOPICS } from '@/data/business';
import Button from '@/components/Button.astro';

/**
 * お問い合わせフォーム。
 * 送信先は /api/contact （workers/contact-email のWorker）。
 * Worker が Cloudflare Email Routing 経由で kuroroji.ch@gmail.com にメールを届ける。
 */

const inputClass =
  'w-full rounded-card border border-line bg-surface px-3 py-2 text-sm text-body focus:border-ink';
const labelClass = 'block text-sm font-bold text-ink';
---

<BaseLayout
  title="お問い合わせ"
  description="くろろじ技研へのお問い合わせフォームです。動画プロモーションのご相談、ゲームに関する無料相談、取材・コラボのご連絡を受け付けています。"
>
  <PageHeader
    title="お問い合わせ"
    labelEn="Contact"
    lede="動画プロモーションのご相談から、ゲームの届け方に関する簡単なご相談まで、お気軽にご連絡ください。"
  />
  <div class="mx-auto max-w-article px-4 py-8 sm:px-6">
    <Breadcrumbs items={[{ label: 'お問い合わせ' }]} />

    {/* フォーム本体（離脱を防ぐため、ページ上部にフォームを置く） */}
    <form id="contact-form" class="mt-6 space-y-5" novalidate>
      <p class="text-xs text-muted">
        <span class="font-bold text-ink">*</span> の付いた項目は必須です。それ以外は分かる範囲でご記入ください。
      </p>

      <div>
        <label for="company" class={labelClass}>会社名・団体名</label>
        <input
          id="company"
          name="company"
          type="text"
          autocomplete="organization"
          class:list={['mt-1.5', inputClass]}
        />
      </div>

      <div>
        <label for="name" class={labelClass}>お名前 <span aria-hidden="true">*</span></label>
        <input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class:list={['mt-1.5', inputClass]}
        />
      </div>

      <div>
        <label for="email" class={labelClass}>メールアドレス <span aria-hidden="true">*</span></label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class:list={['mt-1.5', inputClass]}
        />
      </div>

      <div>
        <label for="topic" class={labelClass}>相談内容の種類 <span aria-hidden="true">*</span></label>
        <select id="topic" name="topic" required class:list={['mt-1.5', inputClass]}>
          
          {CONTACT_TOPICS.map((topic, i) => <option value={topic} selected={i === 0}>{topic}</option>)}<option value="その他">その他</option>
        </select>

        {/* 「ゲームに関する無料相談」を選んだときだけ表示される注釈 */}
        <div id="consultation-note" hidden class="glass mt-3 rounded-card p-5">
          <p class="text-sm font-bold text-ink">{CONSULTATION.title}</p>
          <p class="mt-2 text-xs leading-relaxed text-body">{CONSULTATION.description}</p>
          <p class="mt-2 text-xs font-bold text-ink">相談できるテーマの例</p>
          <ul class="mt-1 space-y-1 text-xs text-body">
            {
              CONSULTATION.themes.map((theme) => (
                <li class="flex gap-2">
                  <span aria-hidden="true" class="mt-2 block h-px w-3 shrink-0 bg-ink" />
                  {theme}
                </li>
              ))
            }
          </ul>
          <p class="mt-2 text-xs text-muted">{CONSULTATION.note}</p>
        </div>
      </div>

      <div>
        <label for="detail" class={labelClass}>詳細内容 <span aria-hidden="true">*</span></label>
        <textarea id="detail" name="detail" rows="6" required class:list={['mt-1.5', inputClass]}
        ></textarea>
      </div>

      {/* ハニーポット（スパムボット対策）。人間には見えない欄で、埋まっていたらWorker側で破棄する */}
      <div class="hidden" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <div>
        <Button type="submit" variant="dark">送信する</Button>
      </div>

      {/* 送信成功の案内 */}
      <div
        id="form-success"
        hidden
        role="status"
        class="rounded-card border border-line bg-accent-faint px-4 py-3 text-sm text-body"
      >
        <p class="font-bold text-ink">送信しました。お問い合わせありがとうございます!</p>
        <p class="mt-1">内容を確認のうえ、ご記入いただいたメールアドレス宛にご連絡します。</p>
      </div>

      {/* 送信失敗の案内 */}
      <div
        id="form-error"
        hidden
        role="alert"
        class="rounded-card border border-line bg-accent-faint px-4 py-3 text-sm text-body"
      >
        <p class="font-bold text-ink">送信に失敗しました。</p>
        <p class="mt-1">時間をおいて再度お試しください。{CONTACT.note}</p>
      </div>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successNotice = document.getElementById('form-success');
  const errorNotice = document.getElementById('form-error');

  // 「ゲームに関する無料相談」を選んだときだけ、相談範囲の注釈を表示する
  const topicSelect = document.getElementById('topic') as HTMLSelectElement | null;
  const consultationNote = document.getElementById('consultation-note');
  topicSelect?.addEventListener('change', () => {
    if (topicSelect.value === 'ゲームに関する無料相談') {
      consultationNote?.removeAttribute('hidden');
    } else {
      consultationNote?.setAttribute('hidden', '');
    }
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    successNotice?.setAttribute('hidden', '');
    errorNotice?.setAttribute('hidden', '');

    // novalidate を付けているため、ここで手動でネイティブ検証を走らせる
    if (!form.reportValidity()) return;

    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const originalLabel = submitButton?.textContent ?? '送信する';
    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = '送信中…';
    }

    try {
      const data = Object.fromEntries(new FormData(form).entries());
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(data),
      });
      const result = (await res.json().catch(() => null)) as { ok?: boolean } | null;
      if (!res.ok || !result?.ok) throw new Error('send failed');

      form.reset();
      successNotice?.removeAttribute('hidden');
      successNotice?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } catch {
      errorNotice?.removeAttribute('hidden');
      errorNotice?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = originalLabel;
      }
    }
  });
</script>
