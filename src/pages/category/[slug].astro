---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { CATEGORIES, type Category } from '@/data/categories';
import { getPublishedArticles } from '@/utils/articles';

export async function getStaticPaths() {
  return CATEGORIES.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

interface Props {
  category: Category;
}

const { category } = Astro.props;
const articles = (await getPublishedArticles()).filter(
  (a) => a.data.category === category.slug,
);
---

<BaseLayout
  title={`${category.name}の記事一覧`}
  description={category.description}
>
  <PageHeader
    title={category.name}
    labelEn={`Category / ${category.slug}`}
    lede={category.description}
  />
  <div class="mx-auto max-w-site px-4 py-8 sm:px-6">
    <Breadcrumbs
      items={[
        { label: 'カテゴリー一覧', href: '/category/' },
        { label: category.name },
      ]}
    />
    {
      articles.length > 0 ? (
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {articles.map((article) => (
            <ArticleCard article={article} titleTag="h2" />
          ))}
        </div>
      ) : (
        <div class="mt-6 rounded-card border border-line bg-surface p-8 text-center">
          <p class="text-sm text-muted">
            このカテゴリーの記事は準備中です。公開までしばらくお待ちください。
          </p>
          <p class="mt-3">
            <a
              href="/articles/"
              class="text-sm text-accent-strong underline underline-offset-4 hover:text-ink"
            >
              すべての記事を見る
            </a>
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>
