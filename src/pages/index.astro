---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import Button from '@/components/Button.astro';
import { SITE, AUTHOR } from '@/data/site';
import { CHANNEL, PROMOTION, CONSULTATION, COLUMN } from '@/data/business';
import { CATEGORIES } from '@/data/categories';
import { getPublishedArticles } from '@/utils/articles';

const articles = await getPublishedArticles();
const latest = articles.slice(0, 6);

/** トップページの構造化データ（WebSite） */
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    alternateName: SITE.nameEn,
    description: SITE.description,
    url: Astro.site?.toString(),
    publisher: {
      '@type': 'Person',
      name: AUTHOR.name,
    },
  },
];

/** セクション見出し共通の番号ラベル */
const sections = {
  channel: { no: '01', en: 'Channel' },
  promotion: { no: '02', en: 'Promotion' },
  media: { no: '03', en: 'Column' },
  contact: { no: '04', en: 'Contact' },
};

/** お問い合わせセクションのバブル装飾（位置・大きさ・速さをばらけさせる） */
const bubbles = [
  { left: '8%', size: '3.5rem', duration: 17, delay: 0 },
  { left: '22%', size: '2rem', duration: 13, delay: 4 },
  { left: '45%', size: '5rem', duration: 21, delay: 2 },
  { left: '62%', size: '2.5rem', duration: 12, delay: 7 },
  { left: '78%', size: '4rem', duration: 18, delay: 5 },
  { left: '91%', size: '1.75rem', duration: 14, delay: 9 },
];
---

<BaseLayout title={SITE.name} description={SITE.description} isHome jsonLd={jsonLd}>
  {/* ============ 1. ファーストビュー（白・方眼が流れる） ============ */}
  <section class="hero-bg relative overflow-hidden border-b border-line">
    {/* ダイナミックな装飾（モノクロ・CSSのみ） */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <span
        class="spin-slow absolute -top-32 -right-32 size-[30rem] rounded-full border border-line-strong/70 border-t-ink/40 sm:size-[36rem]"
      ></span>
      <span class="drift absolute -bottom-24 -left-24 size-[22rem] rounded-full border border-line-strong/50"></span>
      <span class="absolute bottom-[26%] left-[-6%] h-px w-[46%] -rotate-6 bg-line-strong/70"></span>
      <span class="float-slow absolute top-[16%] left-[7%] size-3 rounded-full bg-ink/20"></span>
      <span class="float-slower absolute top-[64%] right-[9%] size-2 rounded-full bg-ink/25"></span>
      <span class="float-slow absolute bottom-[18%] left-[18%] size-7 rotate-12 border border-line-strong/70"></span>
    </div>

    <div class="relative mx-auto max-w-site px-4 pt-12 sm:px-6 sm:pt-16 lg:pt-20">
      <div class="grid items-end gap-6 lg:grid-cols-[1fr_22rem] lg:gap-10">
        <div class="pb-10 sm:pb-14 lg:pb-20">
          <p class="font-mono text-xs tracking-widest text-muted uppercase">
            Game Discovery / YouTube / Promotion
          </p>
          <h1 class="mt-4 text-4xl leading-[1.2] font-bold text-ink sm:text-6xl">
            {SITE.taglineLines.map((line) => <span class="block">{line}</span>)}
          </h1>
          <p class="mt-5 max-w-xl text-sm leading-relaxed text-body sm:text-base">
            {SITE.description}
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <Button href={CHANNEL.url} variant="dark" external>YouTubeを見る</Button>
            <Button href="/contact/" variant="glass">動画案件を相談する</Button>
            <a
              href="/articles/"
              class="nav-link inline-block py-2 text-sm font-bold text-body hover:text-ink"
            >
              記事を読む
            </a>
          </div>
          {/* 信頼の裏付け（ファーストビュー内に実績を明示） */}
          <p class="mt-4 text-xs text-muted">
            動画プロモーション実績：{PROMOTION.clients.slice(0, 2).join('、')} ほか
          </p>

          {/* スクロール誘導 */}
          <div aria-hidden="true" class="mt-10 flex flex-col items-start gap-1.5 lg:mt-14">
            <span class="font-mono text-[0.625rem] tracking-widest text-muted uppercase">Scroll</span>
            <span class="relative ml-3 block h-8 w-px overflow-hidden bg-line-strong">
              <span class="scroll-hint-dot absolute top-0 left-1/2 h-3 w-px -translate-x-1/2 bg-ink"></span>
            </span>
          </div>
        </div>

        {/* 立ち絵：背後のリングと方眼の上に立つ */}
        <div class="relative mx-auto w-60 sm:w-72 lg:w-full">
          <span
            aria-hidden="true"
            class="drift-rev absolute top-[12%] left-1/2 size-[85%] -translate-x-1/2 rounded-full border border-line-strong/80 bg-surface/50"
          ></span>
          <img
            src={AUTHOR.standingImage}
            alt="くろろじのイラスト"
            width="720"
            height="931"
            class="relative w-full drop-shadow-[0_16px_40px_rgb(17_17_17/0.18)]"
          />
        </div>
      </div>
    </div>
  </section>

  {/* ============ 2. くろろじちゃんねる紹介（黒） ============ */}
  <section
    id="channel"
    aria-labelledby="channel-heading"
    class="relative scroll-mt-24 overflow-hidden bg-ink text-paper"
  >
    {/* 流れる斜めライン+うねる波 */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="diag-lines absolute inset-0"></div>
      <div class="absolute inset-x-0 bottom-0 h-24 overflow-hidden">
        <div class="wave-track absolute bottom-0 left-0 h-full">
          <svg class="h-full w-1/2 shrink-0" viewBox="0 0 720 80" preserveAspectRatio="none">
            <path
              d="M0 40 C120 5 240 75 360 40 C480 5 600 75 720 40 L720 80 L0 80 Z"
              fill="rgb(255 255 255 / 0.06)"></path>
          </svg>
          <svg class="h-full w-1/2 shrink-0" viewBox="0 0 720 80" preserveAspectRatio="none">
            <path
              d="M0 40 C120 5 240 75 360 40 C480 5 600 75 720 40 L720 80 L0 80 Z"
              fill="rgb(255 255 255 / 0.06)"></path>
          </svg>
        </div>
        <div class="wave-track wave-track-rev absolute bottom-0 left-0 h-full">
          <svg class="h-full w-1/2 shrink-0" viewBox="0 0 720 80" preserveAspectRatio="none">
            <path
              d="M0 58 C120 30 240 82 360 58 C480 34 600 84 720 58 L720 80 L0 80 Z"
              fill="rgb(255 255 255 / 0.05)"></path>
          </svg>
          <svg class="h-full w-1/2 shrink-0" viewBox="0 0 720 80" preserveAspectRatio="none">
            <path
              d="M0 58 C120 30 240 82 360 58 C480 34 600 84 720 58 L720 80 L0 80 Z"
              fill="rgb(255 255 255 / 0.05)"></path>
          </svg>
        </div>
      </div>
    </div>
    <div class="relative mx-auto max-w-site px-4 py-16 sm:px-6 sm:py-20">
      <p class="font-mono text-xs tracking-widest text-line-strong uppercase">
        {sections.channel.no} — {sections.channel.en}
      </p>
      <h2 id="channel-heading" class="mt-2 text-2xl font-bold text-white sm:text-3xl">
        {CHANNEL.name}
      </h2>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-line-strong sm:text-base">
        {CHANNEL.description}
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          CHANNEL.features.map((feature, i) => (
            <div class="glass-dark rounded-card p-5">
              <p class="font-mono text-3xl font-bold text-white/25" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </p>
              <h3 class="mt-2 text-sm font-bold text-white">{feature.title}</h3>
              <p class="mt-2 text-xs leading-relaxed text-line-strong">{feature.body}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8">
        <Button href={CHANNEL.url} variant="light" external>チャンネルを見る</Button>
      </div>
    </div>
  </section>

  {/* ============ 3. 動画プロモーション・案件実績（白） ============ */}
  <section
    id="promotion"
    aria-labelledby="promotion-heading"
    class="relative scroll-mt-24 overflow-hidden bg-surface"
  >
    {/* 幾何学パターン+回転する図形（ラインは1.5px固定） */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="geo-pattern absolute inset-0"></div>
      <svg class="spin-slow absolute -top-16 right-[6%] size-48 text-line-strong" viewBox="0 0 100 100" fill="none">
        <polygon
          points="50,6 88,28 88,72 50,94 12,72 12,28"
          stroke="currentColor"
          stroke-width="1.5"
          vector-effect="non-scaling-stroke"></polygon>
      </svg>
      <svg class="drift absolute bottom-[8%] left-[4%] size-32 text-line-strong" viewBox="0 0 100 100" fill="none">
        <polygon
          points="50,10 92,85 8,85"
          stroke="currentColor"
          stroke-width="1.5"
          vector-effect="non-scaling-stroke"></polygon>
      </svg>
      <svg class="drift-rev absolute top-[38%] right-[20%] size-14 text-line-strong" viewBox="0 0 100 100" fill="none">
        <path
          d="M50 15 V85 M15 50 H85"
          stroke="currentColor"
          stroke-width="1.5"
          vector-effect="non-scaling-stroke"></path>
      </svg>
    </div>
    <div class="relative mx-auto max-w-site px-4 py-16 sm:px-6 sm:py-20">
      <p class="font-mono text-xs tracking-widest text-muted uppercase">
        {sections.promotion.no} — {sections.promotion.en}
      </p>
      <h2 id="promotion-heading" class="mt-2 text-2xl font-bold sm:text-3xl">
        動画プロモーション
      </h2>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-body sm:text-base">
        ゲーム会社・パブリッシャー様向けに、実際のプレイを通した動画プロモーションをお受けしています。「どんなゲームで、誰におすすめか」が伝わる紹介を大切にしています。
      </p>

      <h3 class="mt-10 text-lg font-bold text-ink">対応可能な内容</h3>
      <div class="mt-4 grid gap-4 lg:grid-cols-3">
        {
          PROMOTION.services.map((service) => (
            <div class="glass rounded-card p-5">
              <h4 class="font-bold text-ink">{service.title}</h4>
              <p class="mt-2 text-xs text-muted">{service.body}</p>
              <ul class="mt-3 space-y-1.5 text-sm text-body">
                {service.points.map((point) => (
                  <li class="flex gap-2">
                    <span aria-hidden="true" class="mt-2.5 block h-px w-3 shrink-0 bg-ink" />
                    {point}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
      <p class="mt-4 text-xs text-muted">{PROMOTION.disclosureNote}</p>

      <h3 class="mt-10 text-lg font-bold text-ink">得意ジャンル</h3>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          PROMOTION.genres.map((genre) => (
            <li class="rounded-full border border-line bg-paper/70 px-4 py-1.5 text-sm text-body backdrop-blur-sm">
              {genre}
            </li>
          ))
        }
      </ul>
      <p class="mt-3 text-xs text-muted">{PROMOTION.genreNote}</p>

      <h3 class="mt-10 text-lg font-bold text-ink">実績</h3>
      <ul class="mt-4 space-y-2 text-sm text-body">
        {
          PROMOTION.clients.map((client) => (
            <li class="flex gap-2">
              <span aria-hidden="true" class="mt-2.5 block h-px w-3 shrink-0 bg-ink" />
              {client}
            </li>
          ))
        }
      </ul>

      <div class="mt-10 flex flex-wrap gap-3">
        <Button href={PROMOTION.playlistUrl} variant="glass" external>
          過去のプロモーション動画を見る
        </Button>
        <Button href="/contact/" variant="dark">動画プロモーションを相談する</Button>
      </div>
    </div>
  </section>

  {/* ============ 4. メディア記事（黒） ============ */}
  <section
    id="media"
    aria-labelledby="media-heading"
    class="relative scroll-mt-24 overflow-hidden bg-ink text-paper"
  >
    {/* 横に流れる縦線（2層・速度差あり） */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="vlines absolute inset-0"></div>
      <div class="vlines-sub absolute inset-0"></div>
    </div>
    <div class="relative mx-auto max-w-site px-4 py-16 sm:px-6 sm:py-20">
      <p class="font-mono text-xs tracking-widest text-line-strong uppercase">
        {sections.media.no} — {sections.media.en}
      </p>
      <div class="mt-2 flex flex-wrap items-baseline justify-between gap-4">
        <h2 id="media-heading" class="text-2xl font-bold text-white sm:text-3xl">
          {COLUMN.name}
        </h2>
        <a
          href="/articles/"
          class="text-sm font-bold text-paper underline underline-offset-4 hover:text-white"
        >
          すべての記事を見る
        </a>
      </div>
      <p class="mt-3 max-w-2xl text-xs text-line-strong">{COLUMN.aiNote}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {
          CATEGORIES.map((category) => (
            <a
              href={`/category/${category.slug}/`}
              class="rounded-full border border-white/25 px-4 py-1.5 text-sm text-paper backdrop-blur-sm transition-colors hover:border-white hover:text-white"
            >
              {category.name}
            </a>
          ))
        }
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {latest.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  {/* ============ 5. お問い合わせ（白） ============ */}
  <section
    id="contact"
    aria-labelledby="contact-heading"
    class="relative scroll-mt-24 overflow-hidden bg-surface"
  >
    {/* 浮かび上がるバブル */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      {
        bubbles.map((b) => (
          <span
            class="bubble"
            style={`left:${b.left};width:${b.size};height:${b.size};animation-duration:${b.duration}s;animation-delay:${b.delay}s;`}
          />
        ))
      }
    </div>
    <div class="relative mx-auto max-w-site px-4 py-16 sm:px-6 sm:py-20">
      <p class="font-mono text-xs tracking-widest text-muted uppercase">
        {sections.contact.no} — {sections.contact.en}
      </p>
      <h2 id="contact-heading" class="mt-2 text-2xl font-bold sm:text-3xl">お問い合わせ</h2>
      <div class="mt-8 grid gap-4 lg:grid-cols-2">
        <div class="glass rounded-card p-6">
          <p class="font-mono text-3xl font-bold text-ink/20" aria-hidden="true">01</p>
          <h3 class="mt-2 font-bold text-ink">動画プロモーション・案件のご相談</h3>
          <p class="mt-2 text-sm leading-relaxed text-body">
            ゲーム紹介動画・まとめ動画での紹介・配信など、内容に応じてご提案します。まずはゲームタイトルと想定内容をお聞かせください。
          </p>
        </div>
        <div class="glass rounded-card p-6">
          <p class="font-mono text-3xl font-bold text-ink/20" aria-hidden="true">02</p>
          <h3 class="mt-2 font-bold text-ink">{CONSULTATION.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-body">{CONSULTATION.description}</p>
          <p class="mt-2 text-xs text-muted">{CONSULTATION.note}</p>
        </div>
      </div>
      <div class="mt-8">
        <Button href="/contact/" variant="dark">お問い合わせフォームへ</Button>
      </div>
    </div>
  </section>
</BaseLayout>
