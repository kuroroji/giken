---
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import FloatingToc from '@/components/FloatingToc.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import AuthorProfile from '@/components/AuthorProfile.astro';
import ContactFormEmbed from '@/components/ContactFormEmbed.astro';
import RelatedArticles from '@/components/RelatedArticles.astro';
import Button from '@/components/Button.astro';
import { getCategory } from '@/data/categories';
import { CHANNEL } from '@/data/business';
import {
  getPublishedArticles,
  pickAdjacent,
  pickRelated,
  type Article,
} from '@/utils/articles';
import { formatDate, toISODate } from '@/utils/date';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

interface Props {
  article: Article;
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const data = article.data;

/** 目次用の見出し一覧。本文の見出しに加え、記事の外で描画するFAQセクションも載せる */
const tocHeadings =
  data.faq.length > 0
    ? [...headings, { depth: 2, slug: 'article-faq-heading', text: 'よくある質問' }]
    : headings;
const category = getCategory(data.category);

const articles = await getPublishedArticles();
const related = pickRelated(article, articles, 3);
const { prev, next } = pickAdjacent(article, articles);

const hasReviewInfo =
  data.productName || data.rating || data.pros.length > 0 || data.cons.length > 0;

/** OGP画像。手動サムネイルがなければ自動生成画像（/og/…）を使う */
const ogImage = data.thumbnail ?? `/og/${article.id}.png`;

/** 記事の構造化データ（Article。FAQがある記事はFAQPageも出力） */
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: data.title,
    description: data.description,
    datePublished: toISODate(data.publishedAt),
    dateModified: toISODate(data.updatedAt ?? data.publishedAt),
    author: {
      '@type': 'Person',
      name: data.author,
      url: new URL('/profile/', Astro.site).toString(),
    },
    image: new URL(ogImage, Astro.site).toString(),
    mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
  },
  ...(data.faq.length > 0
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: data.faq.map((item) => ({
            '@type': 'Question',
            name: item.q,
            acceptedAnswer: { '@type': 'Answer', text: item.a },
          })),
        },
      ]
    : []),
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  ogType="article"
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article>
    <div class="mx-auto max-w-article px-4 py-8 sm:px-6">
      <Breadcrumbs
        items={[
          { label: 'くろろじコラム', href: '/articles/' },
          ...(category
            ? [{ label: category.name, href: `/category/${category.slug}/` }]
            : []),
          { label: data.title },
        ]}
      />

      <header class="mt-6">
        <p class="flex flex-wrap items-center gap-2 text-xs">
          {
            category && (
              <a
                href={`/category/${category.slug}/`}
                class="rounded-sm bg-accent-soft px-2 py-0.5 font-bold text-ink hover:underline"
              >
                {category.name}
              </a>
            )
          }
          {
            data.tags.map((tag) => (
              <span class="rounded-sm border border-line px-2 py-0.5 text-muted">
                #{tag}
              </span>
            ))
          }
        </p>
        <h1 class="mt-3 text-2xl leading-snug font-bold text-ink sm:text-3xl">
          {data.title}
        </h1>
        <p class="mt-3 text-sm text-muted">{data.description}</p>
        <div
          class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 border-y border-line py-2.5 text-xs text-muted"
        >
          <span>
            公開：<time datetime={toISODate(data.publishedAt)} class="font-mono"
              >{formatDate(data.publishedAt)}</time
            >
          </span>
          {
            data.updatedAt && (
              <span>
                更新：
                <time datetime={toISODate(data.updatedAt)} class="font-mono">
                  {formatDate(data.updatedAt)}
                </time>
              </span>
            )
          }
          <span>著者：{data.author}</span>
        </div>
      </header>

      {
        data.thumbnail ? (
          <img
            src={data.thumbnail}
            alt={data.thumbnailAlt ?? ''}
            width="1200"
            height="630"
            class="mt-6 aspect-[1200/630] w-full rounded-card border border-line object-cover"
          />
        ) : (
          <div
            aria-hidden="true"
            class="mt-6 flex w-full flex-col items-center justify-center gap-3 rounded-card bg-ink px-6 py-10 text-center"
          >
            <span class="font-mono text-sm tracking-[0.35em] text-white/60 uppercase">
              Kuroroji Giken
            </span>
            <span class="font-serif text-base leading-snug font-bold tracking-wide text-white sm:text-2xl">
              {
                data.eyecatchLines.length > 0
                  ? data.eyecatchLines.map((line) => <span class="block">{line}</span>)
                  : data.title
              }
            </span>
          </div>
        )
      }

      <div class="mt-6 space-y-6">
        {data.affiliateDisclosure && <AffiliateDisclosure />}

        <TableOfContents headings={tocHeadings} />

        {/* 記事前半のテキストCTA（読み物の邪魔をしない軽い導線） */}
        <p class="text-sm text-body">
          <span aria-hidden="true" class="mr-1">▶</span>実際のプレイ映像・解説動画は
          <a
            href={CHANNEL.url}
            target="_blank"
            rel="noopener"
            class="font-bold text-ink underline underline-offset-4 hover:text-accent-strong"
            >{CHANNEL.name}</a
          >で公開しています。
        </p>

        {
          hasReviewInfo && (
            <aside
              aria-label="レビュー概要"
              class="rounded-card border border-line bg-surface p-5"
            >
              {data.productName && (
                <p class="font-bold text-ink">{data.productName}</p>
              )}
              {data.rating && (
                <p class="mt-1 text-sm text-muted">
                  評価：<span class="font-mono font-bold text-ink">{data.rating}</span>
                  <span class="font-mono"> / 5</span>
                </p>
              )}
              <div class="mt-3 grid gap-4 sm:grid-cols-2">
                {data.pros.length > 0 && (
                  <div>
                    <p class="text-sm font-bold text-ink">良かった点</p>
                    <ul class="mt-1 list-disc pl-5 text-sm text-body">
                      {data.pros.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
                {data.cons.length > 0 && (
                  <div>
                    <p class="text-sm font-bold text-ink">気になった点</p>
                    <ul class="mt-1 list-disc pl-5 text-sm text-body">
                      {data.cons.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </aside>
          )
        }

        <div class="article-body">
          <Content />
        </div>

        {
          data.faq.length > 0 && (
            <section aria-labelledby="article-faq-heading">
              <h2 id="article-faq-heading" class="font-serif text-xl font-bold text-ink sm:text-2xl">
                よくある質問
              </h2>
              <div class="mt-4 border-t border-line">
                {data.faq.map((item) => (
                  <details class="group border-b border-line">
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 font-bold text-ink [&::-webkit-details-marker]:hidden">
                      <span class="text-sm leading-relaxed sm:text-base">{item.q}</span>
                      <span
                        aria-hidden="true"
                        class="shrink-0 font-serif text-xl leading-none text-muted transition-transform duration-200 group-open:rotate-45"
                      >
                        +
                      </span>
                    </summary>
                    <p class="pb-5 text-sm leading-relaxed text-body">{item.a}</p>
                  </details>
                ))}
              </div>
            </section>
          )
        }

        {
          data.contactForm && (
            <section
              id="contact-form"
              aria-labelledby="article-contact-heading"
              class="rounded-card border border-line bg-surface p-6 sm:p-8"
            >
              <p class="font-mono text-xs tracking-widest text-muted uppercase">Contact</p>
              <h2 id="article-contact-heading" class="mt-1.5 font-serif text-xl font-bold text-ink sm:text-2xl">
                この記事から、そのままご相談いただけます
              </h2>
              <p class="mt-2 text-sm leading-relaxed text-body">
                ゲームタイトルと想定内容をお聞かせください。「まだ検討段階」「予算をどうすればいいか相談したい」という段階でも大丈夫です。内容を確認のうえ、ご返信します。
              </p>
              <div class="mt-6">
                <ContactFormEmbed idPrefix="article-cf" submitLabel="この内容で相談する" />
              </div>
            </section>
          )
        }

        {
          data.sourceLinks.length > 0 && (
            <section aria-labelledby="sources-heading" class="border-t border-line pt-6">
              <h2 id="sources-heading" class="text-base font-bold">
                参考リンク
              </h2>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm">
                {data.sourceLinks.map((link) => (
                  <li>
                    <a
                      href={link.url}
                      rel="noopener"
                      class="text-accent-strong underline underline-offset-4 hover:text-ink"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {/* 記事末尾のCTA（読了ユーザー向け・才流メソッドに基づく配置） */}
        <aside aria-label="くろろじからのご案内" class="glass rounded-card p-6">
          <p class="font-mono text-xs tracking-widest text-muted uppercase">From Kuroroji</p>
          <p class="mt-1.5 font-bold text-ink">
            この記事は、ゲーム発掘YouTuber くろろじが書いています
          </p>
          <p class="mt-2 text-sm leading-relaxed text-body">
            YouTube「{CHANNEL.name}」でゲームの発掘・紹介動画を公開中です。ゲーム会社様向けの動画プロモーションのご相談も受け付けています。
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <Button href={CHANNEL.url} variant="dark" external>チャンネルを見る</Button>
            <Button href="/promotion/" variant="glass">動画案件を相談する</Button>
          </div>
        </aside>

        <AuthorProfile />

        <nav aria-label="前後の記事" class="grid gap-3 sm:grid-cols-2">
          {
            prev ? (
              <a
                href={`/articles/${prev.id}/`}
                class="rounded-card border border-line bg-surface p-4 transition-colors hover:border-line-strong"
              >
                <span class="text-xs text-muted">← 前の記事</span>
                <span class="mt-1 line-clamp-2 block text-sm font-bold text-ink">
                  {prev.data.title}
                </span>
              </a>
            ) : (
              <span aria-hidden="true" />
            )
          }
          {
            next && (
              <a
                href={`/articles/${next.id}/`}
                class="rounded-card border border-line bg-surface p-4 text-right transition-colors hover:border-line-strong"
              >
                <span class="text-xs text-muted">次の記事 →</span>
                <span class="mt-1 line-clamp-2 block text-sm font-bold text-ink">
                  {next.data.title}
                </span>
              </a>
            )
          }
        </nav>
      </div>
    </div>

    <div class="mx-auto max-w-site px-4 pb-12 sm:px-6">
      <RelatedArticles articles={related} />
    </div>

    <FloatingToc headings={tocHeadings} />
  </article>
</BaseLayout>
