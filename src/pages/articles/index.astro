---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { COLUMN } from '@/data/business';
import { getPublishedArticles } from '@/utils/articles';

const articles = await getPublishedArticles();
---

<BaseLayout
  title={COLUMN.name}
  description={`${COLUMN.name}の記事一覧です。ゲームの紹介・序盤感想と、YouTubeの始め方に関する記事を新着順に掲載しています。`}
>
  <PageHeader
    title={COLUMN.name}
    labelEn="Column"
    lede={`公開中の記事 ${articles.length}件を新着順に掲載しています。${COLUMN.aiNote}`}
  />
  <div class="mx-auto max-w-site px-4 py-8 sm:px-6">
    <Breadcrumbs items={[{ label: COLUMN.name }]} />
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => <ArticleCard article={article} titleTag="h2" />)}
    </div>
  </div>
</BaseLayout>
